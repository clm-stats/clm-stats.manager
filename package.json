{
  "name": "clm-stats.manager",
  "version": "1.0.0",
  "description": "clm-stats management scripts/web interface",
  "homepage": "https://github.com/clm-stats/clm-stats.manager#readme",
  "bugs": {
    "url": "https://github.com/clm-stats/clm-stats.manager/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clm-stats/clm-stats.manager.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "_": "node -r @babel/register",
    "clean:parcel": "rimraf ./.parcel-cache",
    "clean:dist": "rimraf ./dist",
    "clean": "run-p clean:*",
    "dev:fe": "parcel index.html",
    "dev:be": "nodemon index.js",
    "dev": "run-p dev:*",
    "build": "parcel build index.html",
    "start": "node index.js"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "parcel": "^2.16.4"
  },
  "imports": {
    "#lib/*": "./lib/*.js"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/register": "^7.28.6",
    "@preact/preset-vite": "^2.10.3",
    "@tailwindcss/postcss": "^4.2.1",
    "babel-plugin-jsx-imports": "^1.0.0",
    "classnames": "^2.5.1",
    "clm-stats.app": "file:./clm-stats.app",
    "daisyui": "^5.5.19",
    "env-paths": "^4.0.0",
    "execa": "^9.6.1",
    "express": "^5.2.1",
    "graphql": "^16.13.1",
    "graphql-request": "^7.4.0",
    "iron-session": "^8.0.4",
    "mkdirp": "^3.0.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.8",
    "preact": "^10.28.4",
    "preact-render-to-string": "^6.6.6",
    "react": "npm:@preact/compat",
    "react-dom": "npm:@preact/compat",
    "react-icons": "^5.5.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animated": "^2.0.0",
    "terser": "^5.46.0",
    "vite": "^7.3.1",
    "whr": "^0.3.2"
  },
  "@parcel/resolver-default": {
    "packageExports": true
  }
