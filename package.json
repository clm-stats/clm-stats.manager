{
  "name": "clm-stats.manager",
  "version": "1.0.0",
  "description": "clm-stats management scripts/web interface",
  "homepage": "https://github.com/clm-stats/clm-stats.manager#readme",
  "bugs": {
    "url": "https://github.com/clm-stats/clm-stats.manager/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clm-stats/clm-stats.manager.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "_v": "cross-var cross-env VITE_PORT=$PORT VITE_CLM_STATS_DISCORD_CLIENT_ID=$CLM_STATS_DISCORD_CLIENT_ID vite",
    "clean:dist": "rimraf ./dist",
    "clean": "run-p clean:*",
    "dev:fe": "run-s \"_v -- dev\"",
    "dev:be": "nodemon index.js",
    "dev": "run-p dev:*",
    "build": "run-s \"_v -- build\"",
    "start": "node index.js"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "cross-var": "^1.1.0",
    "nodemon": "^3.1.14"
  },
  "imports": {
    "#app/*": "./app/*.jsx",
    "#lib/*": "./lib/*.js"
  },
  "dependencies": {
    "@preact/preset-vite": "^2.10.3",
    "@tailwindcss/postcss": "^4.2.1",
    "classnames": "^2.5.1",
    "cssnano": "^7.1.3",
    "daisyui": "^5.5.19",
    "env-paths": "^4.0.0",
    "execa": "^9.6.1",
    "express": "^5.2.1",
    "git-client": "^1.9.4",
    "graphql": "^16.13.1",
    "graphql-request": "^7.4.0",
    "html-minifier-terser": "^7.2.0",
    "iron-session": "^8.0.4",
    "mkdirp": "^3.0.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.8",
    "preact": "^10.28.4",
    "preact-render-to-string": "^6.6.6",
    "react": "npm:@preact/compat",
    "react-dom": "npm:@preact/compat",
    "react-icons": "^5.5.0",
    "rimraf": "^6.1.3",
    "string-hash": "^1.1.3",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animated": "^2.0.0",
    "terser": "^5.46.0",
    "vite": "^7.3.1",
    "whr": "^0.3.2"
  }
}
